{
  "sourceLanguage" : "en",
  "strings" : {
    "NSAppleEventsUsageDescription" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "A program running in the embedded terminal may request AppleScript access. Notch Island media controls may also use Apple Events for local music apps." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "嵌入式终端中运行的程序可能会请求 AppleScript 访问权限。Notch Island 媒体控制也可能使用 Apple Events 控制本机音乐应用。" } }
      }
    },
    "NSAppleMusicUsageDescription" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Notch Island can read local Apple Music playback metadata when the media module is enabled." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "启用媒体模块后，Notch Island 可以读取本机 Apple Music 播放元数据。" } }
      }
    },
    "NSAudioCaptureUsageDescription" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Notch Island can capture local audio levels for visualizer modules when audio features are enabled." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "启用音频功能后，Notch Island 可以为可视化模块捕获本机音频电平。" } }
      }
    },
    "NSBluetoothAlwaysUsageDescription" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "A program running in the embedded terminal may request Bluetooth access. Notch Island can show Bluetooth audio device status when enabled." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "嵌入式终端中运行的程序可能会请求蓝牙访问权限。启用后，Notch Island 可以显示蓝牙音频设备状态。" } }
      }
    },
    "NSCalendarsUsageDescription" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "A program running in the embedded terminal may request calendar access." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "嵌入式终端中运行的程序可能会请求日历访问权限。" } }
      }
    },
    "NSCameraUsageDescription" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "A program running in the embedded terminal may request camera access." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "嵌入式终端中运行的程序可能会请求相机访问权限。" } }
