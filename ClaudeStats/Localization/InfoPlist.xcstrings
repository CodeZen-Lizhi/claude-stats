    "NSAppleEventsUsageDescription" : {
      "comment" : "Privacy - AppleEvents Sending Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notch Island media controls may use Apple Events for local music apps."
          }
