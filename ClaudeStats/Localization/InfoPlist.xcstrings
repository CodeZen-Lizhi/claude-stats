    "NSAppleEventsUsageDescription" : {
      "comment" : "Privacy - AppleEvents Sending Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A program running in the embedded terminal may request AppleScript access. Notch Island media controls may also use Apple Events for local music apps."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "嵌入式终端中运行的程序可能会请求 AppleScript 访问权限。Notch Island 媒体控制也可能使用 Apple Events 控制本机音乐应用。"
          }
        }
      }
    },
    "NSAppleMusicUsageDescription" : {
      "comment" : "Privacy - Media Library Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notch Island can read local Apple Music playback metadata when the media module is enabled."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启用媒体模块后，Notch Island 可以读取本机 Apple Music 播放元数据。"
          }
        }
      }
    },
    "NSAudioCaptureUsageDescription" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notch Island can capture local audio levels for visualizer modules when audio features are enabled."
