            "value": "添加终端 bundle id"
          }
        }
      }
    },
    "Adds a GitHub contributions heatmap to the Dashboard plus an Overlap view. Reads contribution counts only.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在仪表盘上添加 GitHub 贡献热力图并提供 Overlap 视图。仅读取贡献计数。"
          }
        }
      }
    },
    "Adds a GitHub heatmap and local-vs-GitHub overlap view to the Dashboard.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在仪表盘添加 GitHub 热力图和本地/GitHub 重叠视图。"
          }
