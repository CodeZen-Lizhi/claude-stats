    "API estimate uses standard first-party token prices. Detailed billing also applies fast mode and web search charges when Claude logs expose them.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "API 估算使用标准的官方令牌价格。当 Claude 日志中包含相关字段时，详细账单还会计入快速模式和网页搜索费用。"
          }
        }
      }
    },
    "API key required": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要 API 密钥"
          }
        }
      }
